#!/bin/bash
# Fired by Claude Code PreToolUse hook — agent is calling a tool
set -e

[ -z "$CLXD_STATUS_DIR" ] && exit 0
: "${CLXD_SLUG:=unknown}"
: "${CLXD_WORKTREE:=unknown}"

mkdir -p "$CLXD_STATUS_DIR"

# Read tool info from stdin
input=$(cat)
tool=$(echo "$input" | jq -r '.tool_name // ""' 2>/dev/null || true)

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
tmp="$CLXD_STATUS_DIR/status.json.tmp"

# Keep updated_at from when the working session started — don't reset the
# clock on every tool call so the dashboard shows total working duration.
current_state=$(jq -r '.state // ""' "$CLXD_STATUS_DIR/status.json" 2>/dev/null || true)
if [ "$current_state" = "working" ]; then
    updated_at=$(jq -r '.updated_at // ""' "$CLXD_STATUS_DIR/status.json" 2>/dev/null || true)
    [ -z "$updated_at" ] && updated_at="$ts"
else
    updated_at="$ts"
fi

cat > "$tmp" <<EOF
{
  "slug": "$CLXD_SLUG",
  "worktree": "$CLXD_WORKTREE",
  "state": "working",
  "message": "$tool",
  "updated_at": "$updated_at"
}
EOF

mv "$tmp" "$CLXD_STATUS_DIR/status.json"
