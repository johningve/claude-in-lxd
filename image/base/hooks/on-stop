#!/bin/bash
# Fired by Claude Code Stop hook — agent finished a response turn
set -e

[ -z "$CLXD_STATUS_DIR" ] && exit 0
: "${CLXD_SLUG:=unknown}"
: "${CLXD_WORKTREE:=unknown}"

mkdir -p "$CLXD_STATUS_DIR"

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
tmp="$CLXD_STATUS_DIR/status.json.tmp"

cat > "$tmp" <<EOF
{
  "slug": "$CLXD_SLUG",
  "worktree": "$CLXD_WORKTREE",
  "state": "idle",
  "message": "",
  "updated_at": "$ts"
}
EOF

mv "$tmp" "$CLXD_STATUS_DIR/status.json"

echo "{\"slug\":\"$CLXD_SLUG\",\"state\":\"idle\",\"ts\":\"$ts\"}" \
  >> "$CLXD_STATUS_DIR/events.jsonl"
