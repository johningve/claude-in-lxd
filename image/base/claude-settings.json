{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "theme": "auto",
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "model": "claude-opus-4-8[1m]",
  "effortLevel": "xhigh",
  "hooks": {
    "Stop": [
      {"hooks": [{"type": "command", "command": "/opt/clxd/hooks/on-stop"}]}
    ],
    "Notification": [
      {"hooks": [{"type": "command", "command": "/opt/clxd/hooks/on-notification"}]}
    ],
    "PreToolUse": [
      {"hooks": [{"type": "command", "command": "/opt/clxd/hooks/on-tool-use"}]}
    ],
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "/opt/clxd/hooks/on-user-prompt"}]}
    ]
  }
}
