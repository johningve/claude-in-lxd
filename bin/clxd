#!/usr/bin/env fish
# clxd — LXD-based isolated Claude Code agent runner
#
# Subcommands:
#   clxd [launch] [--image <img>] [path]   Launch agent in worktree's container (default)
#   clxd launch   --host [path]            Launch agent on host (default permission mode)
#   clxd shell    [path]          Open a bash shell in the container
#   clxd exec     [path] -- cmd   Run a command inside the container
#   clxd status   [--json]        One-shot status table of all sessions
#   clxd dash                     Looping dashboard (runs in byobu status window)
#   clxd attach   [path|slug]     Attach to a session's byobu window
#   clxd ls                       Machine-readable container list
#   clxd stop     [path]          Stop container (keep volumes)
#   clxd destroy  [path]          Stop + delete container
#   clxd gc       [--dry-run]     Remove containers/host sessions whose worktree is gone
#   clxd setup-host               Register hooks in ~/.claude/settings.json (host sessions)
#   clxd build-image [profile] [--from dir]  Build (or rebuild) an image
#   clxd list-images              List local claude-in-lxd* images
#   clxd update-profile           Re-apply profile.yaml to the live LXD profile

# ── Config ────────────────────────────────────────────────────────────────────

set -g CLXD_TMUX_SESSION clxd
set -g CLXD_STATUS_HOST_DIR $HOME/.cache/clxd/status
if test -n "$XDG_CONFIG_HOME"
    set -g CLXD_CONFIG_HOST_DIR $XDG_CONFIG_HOME/clxd
else
    set -g CLXD_CONFIG_HOST_DIR $HOME/.config/clxd
end
set -g CLXD_CONTAINER_STATUS_DIR /opt/clxd-status
set -g CLXD_IMAGE_DEFAULT claude-in-lxd
# Fire notify-send desktop notifications from the dashboard. Set to false to
# disable — e.g. under konsole, where Claude's terminal bell already produces a
# clickable, tab-focusing notification.
set -q CLXD_NOTIFY_SEND; or set -g CLXD_NOTIFY_SEND true
set -g CLXD_CONTAINER_CLAUDE_DIR /home/agent/.claude
set -g CLXD_HOOKS_VERSION 1
# Resolve the repo root from the location of this script
set -g _CLXD_BIN (realpath (status --current-filename))
set -g _CLXD_ROOT (dirname (dirname $_CLXD_BIN))

# Multiplexer abstraction: router + one backend per lib/mux-<name>.fish
source $_CLXD_ROOT/lib/mux.fish
for _mux_backend in $_CLXD_ROOT/lib/mux-*.fish
    source $_mux_backend
end
set -g CLXD_MUX (_clxd_detect_mux)

# Resolve host Claude config dir (honor CLAUDE_CONFIG_DIR)
if test -n "$CLAUDE_CONFIG_DIR"
    set -g _HOST_CLAUDE_DIR $CLAUDE_CONFIG_DIR
else
    set -g _HOST_CLAUDE_DIR $HOME/.claude
end

# Resolve host docker config dir (honor DOCKER_CONFIG)
if test -n "$DOCKER_CONFIG"
    set -g _HOST_DOCKER_DIR $DOCKER_CONFIG
else
    set -g _HOST_DOCKER_DIR $HOME/.docker
end

# Resolve host ccache dir (honor CCACHE_DIR)
if test -n "$CCACHE_DIR"
    set -g _HOST_CCACHE_DIR $CCACHE_DIR
else
    set -g _HOST_CCACHE_DIR $HOME/.ccache
end

# Resolve host halide-cache dir (no standard env var)
set -g _HOST_HALIDE_CACHE_DIR $HOME/.cache/halide-cache

# ── Dispatch ──────────────────────────────────────────────────────────────────

function main
    if test (count $argv) -eq 0
        _clxd_launch $PWD
        return
    end

    switch $argv[1]
        case launch
            _clxd_launch $argv[2..]
        case shell
            _clxd_shell $argv[2..]
        case exec
            _clxd_exec $argv[2..]
        case status
            _clxd_status $argv[2..]
        case dash
            _clxd_dash
        case _dash-ls
            _clxd_dash_ls
        case _dash-preview
            _clxd_dash_preview $argv[2..]
        case _notify-daemon
            _clxd_notify_daemon
        case attach
            _clxd_attach $argv[2..]
        case ls
            _clxd_ls
        case stop
            _clxd_stop $argv[2..]
        case destroy
            _clxd_destroy $argv[2..]
        case gc
            _clxd_gc $argv[2..]
        case setup-host
            _clxd_setup_host_hooks
        case build-image
            _clxd_build_image $argv[2..]
        case list-images
            _clxd_list_images
        case setup-network
            _clxd_setup_network
        case update-profile
            _clxd_update_profile
        case help --help -h
            _clxd_help
        case '*'
            # If the first arg looks like a path and no subcommand, treat as launch
            if test -d $argv[1]
                _clxd_launch $argv
            else
                echo "Unknown command: $argv[1]" >&2
                _clxd_help
                exit 1
            end
    end
end

# ── Worktree helpers ──────────────────────────────────────────────────────────

function _clxd_worktree_info
    # Resolves worktree metadata from a path.
    # Sets caller-visible vars: _wt_path, _wt_main, _wt_repo, _wt_branch
    set path (realpath $argv[1] 2>/dev/null)
    if test -z "$path" -o ! -d "$path"
        echo "Error: path does not exist: $argv[1]" >&2
        return 1
    end

    # Find the toplevel of the worktree
    set toplevel (git -C $path rev-parse --show-toplevel 2>/dev/null)
    if test -z "$toplevel"
        echo "Error: not inside a git repository: $path" >&2
        return 1
    end
    set -g _wt_path $toplevel

    # Find the absolute git dir and derive the main worktree from it
    set abs_git_dir (git -C $path rev-parse --absolute-git-dir 2>/dev/null)
    if string match -qr '\.git/worktrees/' -- $abs_git_dir
        # Linked worktree: strip /worktrees/<name> suffix to get to .git dir
        set main_git (string replace -r '/worktrees/[^/]+/?$' '' $abs_git_dir)
    else
        set main_git $abs_git_dir
    end
    set -g _wt_main (dirname $main_git)

    set -g _wt_branch (basename $_wt_path)
    set -g _wt_repo (basename (dirname $_wt_path))
end

function _clxd_slug
    # Derives a valid LXD container name from a worktree path
    set worktree $argv[1]
    set branch_name (basename $worktree)
    set repo_name (basename (dirname $worktree))

    set raw "$repo_name-$branch_name"
    # Lowercase, replace non-alnum with dash, collapse runs, strip leading/trailing dashes
    set slug (echo $raw \
        | tr '[:upper:]' '[:lower:]' \
        | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//')

    # LXD max name length is 63. "clxd-"(5) + short(49) + "-"(1) + hash(8) = 63.
    if test (string length $slug) -gt 50
        set short (string sub -l 49 $slug)
        set hash (echo -n $worktree | sha1sum | cut -c1-8)
        set slug "$short-$hash"
    end

    echo "clxd-$slug"
end

function _clxd_host_slug
    # Derives a host-session slug from a worktree path: host-<repo>-<branch>
    set worktree $argv[1]
    set branch_name (basename $worktree)
    set repo_name (basename (dirname $worktree))

    set raw "$repo_name-$branch_name"
    set slug (echo $raw \
        | tr '[:upper:]' '[:lower:]' \
        | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//')

    # "host-"(5) + short(49) + "-"(1) + hash(8) = 63 chars max
    if test (string length $slug) -gt 50
        set short (string sub -l 49 $slug)
        set hash (echo -n $worktree | sha1sum | cut -c1-8)
        set slug "$short-$hash"
    end

    echo "host-$slug"
end

function _clxd_resolve_image
    # Resolve image alias for a worktree. Priority:
    #   1. $argv[1] if non-empty (from --image flag)
    #   2. .clxd-image in worktree root
    #   3. .clxd-image in main worktree root
    #   4. CLXD_IMAGE_DEFAULT
    set override $argv[1]
    set worktree $argv[2]
    set main_worktree $argv[3]

    if test -n "$override"
        echo $override
        return
    end

    for candidate in $worktree/.clxd-image $main_worktree/.clxd-image
        if test -f $candidate
            string trim < $candidate
            return
        end
    end

    echo $CLXD_IMAGE_DEFAULT
end

# ── Container lifecycle ───────────────────────────────────────────────────────

function _clxd_create_container
    set name $argv[1]
    set image $argv[2]
    set worktree $argv[3]
    set main_worktree $argv[4]

    set slug (string replace 'clxd-' '' $name)

    echo "Creating container $name from image '$image'..."
    lxc init $image $name --profile default --profile claude-in-lxd; or return 1

    # Store metadata for gc and status
    lxc config set $name user.workspace.host-path=$worktree
    lxc config set $name user.workspace.slug=$slug

    # Same-path bind mount of the worktree (rw)
    lxc config device add $name workspace disk source=$worktree path=$worktree

    # Read-only mount of main worktree (so gwt's absolute symlinks resolve)
    if test "$main_worktree" != "$worktree"
        lxc config device add $name mainworktree disk \
            source=$main_worktree path=$main_worktree readonly=true
    end

    # Per-container status dir on host (bind-mounted into container)
    mkdir -p $CLXD_STATUS_HOST_DIR/$name
    lxc config device add $name clxd-status disk \
        source=$CLXD_STATUS_HOST_DIR/$name path=$CLXD_CONTAINER_STATUS_DIR

    # Bind-mount host compilation caches (rw) when they exist on the host.
    # Both caches handle concurrent access safely, so sharing across containers
    # is fine. raw.idmap maps host UID 1000 ↔ container UID 1000 (agent), so
    # no --uid/--gid flags are needed on the disk devices.
    if test -d $_HOST_CCACHE_DIR
        lxc config device add $name ccache disk \
            source=$_HOST_CCACHE_DIR path=/home/agent/.ccache
    end
    if test -d $_HOST_HALIDE_CACHE_DIR
        lxc config device add $name halide-cache disk \
            source=$_HOST_HALIDE_CACHE_DIR path=/home/agent/.cache/halide-cache
    end

    # Environment variables available to all processes in the container
    lxc config set $name environment.CLXD_SLUG=$slug
    lxc config set $name environment.CLXD_WORKTREE=$worktree
    lxc config set $name environment.CLXD_STATUS_DIR=$CLXD_CONTAINER_STATUS_DIR
    lxc config set $name environment.CLAUDE_CONFIG_DIR=$CLXD_CONTAINER_CLAUDE_DIR
end

function _clxd_wait_for_boot
    set name $argv[1]
    echo "Waiting for container to boot..."
    for i in (seq 1 30)
        if lxc exec $name -- test -S /run/dbus/system_bus_socket 2>/dev/null
            return
        end
        sleep 1
    end
    echo "Warning: D-Bus socket did not appear in 30s" >&2
end

function _clxd_first_boot_setup
    set name $argv[1]

    lxc exec $name -- bash -c '
        set -e
        # Ensure ~/.claude exists and is owned by agent
        mkdir -p /home/agent/.claude
        chown 1000:1000 /home/agent/.claude

        # Seed settings.json with hook config if not yet present
        if [ ! -f /home/agent/.claude/settings.json ] && [ -f /opt/clxd/claude-settings.json ]; then
            cp /opt/clxd/claude-settings.json /home/agent/.claude/settings.json
            chown 1000:1000 /home/agent/.claude/settings.json
        fi

        # Seed base CLAUDE.md instructions if not yet present
        if [ ! -f /home/agent/.claude/CLAUDE.md ] && [ -f /opt/clxd/CLAUDE.md ]; then
            cp /opt/clxd/CLAUDE.md /home/agent/.claude/CLAUDE.md
            chown 1000:1000 /home/agent/.claude/CLAUDE.md
        fi

        # Mark onboarding complete so interactive `claude` skips the first-run
        # login/theme wizard. Auth itself comes from CLAUDE_CODE_OAUTH_TOKEN;
        # without this key the wizard shows a login screen even with a valid token.
        if [ ! -f /home/agent/.claude/.claude.json ]; then
            echo "{\"hasCompletedOnboarding\": true}" > /home/agent/.claude/.claude.json
            chown 1000:1000 /home/agent/.claude/.claude.json
            chmod 600 /home/agent/.claude/.claude.json
        fi

        touch /var/lib/clxd-initialized
    '
end

function _clxd_push_credentials
    set name $argv[1]

    # Authenticate via a dedicated, long-lived credential rather than copying the
    # host's rotating OAuth credentials (.credentials.json). Sharing that file
    # between host and container causes refresh-token rotation to invalidate
    # whichever side didn't refresh last, forcing repeated re-authentication.
    #
    # Preferred: a long-lived token from `claude setup-token`, stored in a token
    # file on the host (kept out of the host environment).
    # Fallback: ANTHROPIC_API_KEY (Console pay-per-token).

    set token_file $CLXD_CONFIG_HOST_DIR/oauth-token

    if test -f $token_file
        set token (string trim (cat $token_file))
        lxc config set $name environment.CLAUDE_CODE_OAUTH_TOKEN=$token
    else if test -n "$ANTHROPIC_API_KEY"
        lxc config set $name environment.ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY
    else
        echo "Warning: No Claude credentials found on host." >&2
        echo "  Run 'claude setup-token' on the host and save the token to:" >&2
        echo "    $token_file" >&2
        echo "  Alternatively set ANTHROPIC_API_KEY." >&2
    end
end

function _clxd_push_docker_config
    set name $argv[1]
    set src $_HOST_DOCKER_DIR/config.json
    if not test -f $src
        return 0
    end
    lxc exec $name -- bash -c \
        'mkdir -p /home/agent/.docker && chown 1000:1000 /home/agent/.docker'
    lxc file push $src \
        $name/home/agent/.docker/config.json \
        --uid 1000 --gid 1000 --mode 600
end

function _clxd_wait_for_docker
    set name $argv[1]
    echo "Waiting for Docker..."
    for i in (seq 1 30)
        if lxc exec $name -- docker info > /dev/null 2>&1
            return
        end
        sleep 1
    end
    echo "Warning: Docker did not become ready in 30s" >&2
end

# ── Write initial status ──────────────────────────────────────────────────────

function _clxd_write_initial_status
    set name $argv[1]
    set slug $argv[2]
    set worktree $argv[3]

    set status_dir $CLXD_STATUS_HOST_DIR/$name
    mkdir -p $status_dir

    set ts (date -u +%Y-%m-%dT%H:%M:%SZ)
    set tmp $status_dir/status.json.tmp
    echo '{
  "slug": "'"$slug"'",
  "worktree": "'"$worktree"'",
  "state": "started",
  "message": "",
  "updated_at": "'"$ts"'"
}' > $tmp
    mv $tmp $status_dir/status.json
end

# ── Subcommands ───────────────────────────────────────────────────────────────

function _clxd_launch
    # Parse: [--image <img>] [--host] [path]
    set image ""
    set path $PWD
    set host_mode false

    set i 1
    while test $i -le (count $argv)
        switch $argv[$i]
            case --image
                set i (math $i + 1)
                set image $argv[$i]
            case --host
                set host_mode true
            case '*'
                set path $argv[$i]
        end
        set i (math $i + 1)
    end

    if $host_mode
        _clxd_launch_host $path
        return
    end

    if not _clxd_worktree_info $path
        exit 1
    end

    set image (_clxd_resolve_image "$image" $_wt_path $_wt_main)
    set name (_clxd_slug $_wt_path)
    set slug (string replace 'clxd-' '' $name)

    _clxd_check_profile_freshness

    # Create container if it doesn't exist
    if not lxc info $name > /dev/null 2>&1
        _clxd_create_container $name $image $_wt_path $_wt_main; or return 1
        if not lxc start $name
            echo "Error: failed to start container $name" >&2
            echo "Run: lxc info --show-log $name" >&2
            return 1
        end
        _clxd_wait_for_boot $name
        _clxd_first_boot_setup $name
    else
        # Start if stopped
        set state (lxc info $name 2>/dev/null | awk '/^Status:/ {print tolower($2)}')
        if test "$state" != running
            echo "Starting container $name..."
            if not lxc start $name
                echo "Error: failed to start container $name" >&2
                echo "Run: lxc info --show-log $name" >&2
                return 1
            end
            _clxd_wait_for_boot $name
        end
    end

    # Set auth credentials on every launch (idempotent; picked up by lxc exec)
    _clxd_push_credentials $name
    _clxd_push_docker_config $name

    # Wait for Docker
    _clxd_wait_for_docker $name

    # Write initial status
    _clxd_write_initial_status $name $slug $_wt_path

    # su without -l: preserves container env (CLAUDE_CONFIG_DIR etc.) and avoids setsid
    set exec_cmd "lxc exec $name --cwd $_wt_path -- su --pty agent -c 'claude'"

    # Open (or reuse) the agent's session in the multiplexer
    _clxd_mux open $slug $exec_cmd

    echo "Agent launched: $name"
    echo "  worktree: $_wt_path"
    echo "  image:    $image"

    _clxd_mux attach $slug
end

function _clxd_launch_host
    set path $PWD
    if test (count $argv) -gt 0
        set path $argv[1]
    end

    if not _clxd_worktree_info $path
        exit 1
    end

    set slug (_clxd_host_slug $_wt_path)
    set status_dir $CLXD_STATUS_HOST_DIR/$slug

    # Lazily register hooks in ~/.claude/settings.json on first use
    _clxd_setup_host_hooks

    # Write initial status
    _clxd_write_initial_status $slug $slug $_wt_path

    set exec_cmd "env CLXD_SLUG=$slug CLXD_WORKTREE=$_wt_path CLXD_STATUS_DIR=$status_dir claude"

    _clxd_mux open $slug $exec_cmd $_wt_path

    echo "Host agent launched: $slug"
    echo "  worktree: $_wt_path"
    echo "  (default permission mode — tool approvals required)"

    _clxd_mux attach $slug
end

function _clxd_setup_host_hooks
    set settings $_HOST_CLAUDE_DIR/settings.json
    set hooks_dir $_CLXD_ROOT/image/base/hooks

    mkdir -p $_HOST_CLAUDE_DIR
    if not test -f $settings
        echo '{}' > $settings
    end

    set current_version (jq -r '.["clxd.hooks_version"] // 0' $settings 2>/dev/null; or echo 0)
    if test "$current_version" = "$CLXD_HOOKS_VERSION"
        return 0
    end

    echo "Registering clxd hooks in $settings ..."
    set tmp $settings.clxd-tmp
    jq --arg d $hooks_dir --argjson v $CLXD_HOOKS_VERSION '
        .["clxd.hooks_version"] = $v |
        .hooks = ((.hooks // {}) + {
            "Stop":             [{"hooks": [{"type": "command", "command": ($d+"/on-stop")}]}],
            "Notification":     [{"hooks": [{"type": "command", "command": ($d+"/on-notification")}]}],
            "PreToolUse":       [{"hooks": [{"type": "command", "command": ($d+"/on-tool-use")}]}],
            "UserPromptSubmit": [{"hooks": [{"type": "command", "command": ($d+"/on-user-prompt")}]}]
        })
    ' $settings > $tmp; and mv $tmp $settings
    echo "Done. Hook paths: $hooks_dir/on-{stop,notification,tool-use,user-prompt}"
end

function _clxd_shell
    set path $PWD
    if test (count $argv) -gt 0
        set path $argv[1]
    end

    if not _clxd_worktree_info $path
        exit 1
    end

    set name (_clxd_slug $_wt_path)

    if not lxc info $name > /dev/null 2>&1
        echo "No container for this worktree. Run 'clxd launch' first." >&2
        exit 1
    end

    set state (lxc info $name 2>/dev/null | awk '/^Status:/ {print tolower($2)}')
    if test "$state" != running
        if not lxc start $name
            echo "Error: failed to start container $name" >&2
            return 1
        end
        _clxd_wait_for_boot $name
    end

    # su without -l: no setsid, so bash stays in lxc exec's PTY session (job control works)
    lxc exec $name --cwd $_wt_path -- su agent
end

function _clxd_exec
    # clxd exec [path] -- cmd [args...]
    set path $PWD
    set cmd_args

    # Find the -- separator
    set sep_idx 0
    for i in (seq 1 (count $argv))
        if test "$argv[$i]" = "--"
            set sep_idx $i
            break
        end
    end

    if test $sep_idx -eq 0
        echo "Usage: clxd exec [path] -- <command> [args...]" >&2
        exit 1
    end

    if test $sep_idx -gt 1
        set path $argv[1]
    end
    set cmd_args $argv[(math $sep_idx + 1)..]

    if not _clxd_worktree_info $path
        exit 1
    end

    set name (_clxd_slug $_wt_path)

    if not lxc info $name > /dev/null 2>&1
        echo "No container for this worktree. Run 'clxd launch' first." >&2
        exit 1
    end

    set state (lxc info $name 2>/dev/null | awk '/^Status:/ {print tolower($2)}')
    if test "$state" != running
        if not lxc start $name
            echo "Error: failed to start container $name" >&2
            return 1
        end
        _clxd_wait_for_boot $name
    end

    set cmd_str (string join " " $cmd_args)
    lxc exec $name -- su - agent -c "cd $_wt_path && $cmd_str"
end

function _clxd_status
    set json_mode false
    set color_mode (test -t 1; and echo always; or echo never)

    for arg in $argv
        switch $arg
            case --json
                set json_mode true
            case --color
                set color_mode always
            case --no-color
                set color_mode never
        end
    end

    # Gather all clxd containers and host session dirs
    set containers (lxc list --format csv -c n 2>/dev/null | grep '^clxd-'; or true)
    set has_host (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null | head -1)

    if test -z "$containers" -a -z "$has_host"
        if not $json_mode
            echo "No clxd sessions."
        end
        return
    end

    if not $json_mode
        printf "%-46s  %-9s  %-9s  %-45s  %s\n" \
            SLUG STATE CONTAINER WORKTREE UPDATED
        printf "%-46s  %-9s  %-9s  %-45s  %s\n" \
            (string repeat -n 46 -) (string repeat -n 9 -) (string repeat -n 9 -) \
            (string repeat -n 45 -) -------
    end

    # Container rows
    for name in (string split \n $containers)
        test -z "$name"; and continue

        set worktree (lxc config get $name user.workspace.host-path 2>/dev/null)
        set slug (lxc config get $name user.workspace.slug 2>/dev/null)
        set container_state (lxc info $name 2>/dev/null \
            | awk '/^Status:/ {print tolower($2)}')

        set agent_state unknown
        set updated_at --
        set message ""

        set status_file $CLXD_STATUS_HOST_DIR/$name/status.json
        if test -f $status_file
            set agent_state (jq -r '.state // "unknown"' $status_file 2>/dev/null; or echo unknown)
            set updated_at (jq -r '.updated_at // "--"' $status_file 2>/dev/null; or echo --)
            set message (jq -r '.message // ""' $status_file 2>/dev/null; or true)

            if test "$updated_at" != "--"
                set epoch_then (date -d $updated_at +%s 2>/dev/null; or echo 0)
                set epoch_now (date +%s)
                set diff (math $epoch_now - $epoch_then)
                if test $diff -lt 60
                    set updated_at "$diff""s ago"
                else if test $diff -lt 3600
                    set updated_at (math --scale=0 $diff / 60)"m ago"
                else
                    set updated_at (math --scale=0 $diff / 3600)"h ago"
                end
            end
        end

        if $json_mode
            echo '{"slug":"'"$slug"'","container":"'"$name"'","container_state":"'"$container_state"'","agent_state":"'"$agent_state"'","worktree":"'"$worktree"'","updated_at":"'"$updated_at"'"}'
        else
            set state_colored $agent_state
            if test "$color_mode" = always
                switch $agent_state
                    case working
                        set state_colored (printf "\e[36m%s\e[0m" $agent_state)
                    case waiting
                        set state_colored (printf "\e[33m%s\e[0m" $agent_state)
                    case idle
                        set state_colored (printf "\e[32m%s\e[0m" $agent_state)
                    case stopped unknown
                        set state_colored (printf "\e[2m%s\e[0m" $agent_state)
                end
            end

            set display_wt (string replace $HOME '~' $worktree)
            set display_slug $slug
            if test (string length $display_slug) -gt 44
                set display_slug (string sub -l 44 $display_slug)..
            end
            if test (string length $display_wt) -gt 43
                set display_wt ..(string sub -s (math (string length $display_wt) - 41) $display_wt)
            end

            printf "%-46s  %-9s  %-9s  %-45s  %s\n" \
                $display_slug $state_colored $container_state $display_wt $updated_at
        end
    end

    # Host session rows
    for dir in (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null)
        set slug (basename $dir)
        set worktree ""
        set agent_state unknown
        set updated_at --

        set status_file $dir/status.json
        if test -f $status_file
            set worktree (jq -r '.worktree // ""' $status_file 2>/dev/null; or true)
            set agent_state (jq -r '.state // "unknown"' $status_file 2>/dev/null; or echo unknown)
            set updated_at (jq -r '.updated_at // "--"' $status_file 2>/dev/null; or echo --)

            if test "$updated_at" != "--"
                set epoch_then (date -d $updated_at +%s 2>/dev/null; or echo 0)
                set epoch_now (date +%s)
                set diff (math $epoch_now - $epoch_then)
                if test $diff -lt 60
                    set updated_at "$diff""s ago"
                else if test $diff -lt 3600
                    set updated_at (math --scale=0 $diff / 60)"m ago"
                else
                    set updated_at (math --scale=0 $diff / 3600)"h ago"
                end
            end
        end

        if $json_mode
            echo '{"slug":"'"$slug"'","container":"host","container_state":"host","agent_state":"'"$agent_state"'","worktree":"'"$worktree"'","updated_at":"'"$updated_at"'"}'
        else
            set state_colored $agent_state
            if test "$color_mode" = always
                switch $agent_state
                    case working
                        set state_colored (printf "\e[36m%s\e[0m" $agent_state)
                    case waiting
                        set state_colored (printf "\e[33m%s\e[0m" $agent_state)
                    case idle
                        set state_colored (printf "\e[32m%s\e[0m" $agent_state)
                    case stopped unknown
                        set state_colored (printf "\e[2m%s\e[0m" $agent_state)
                end
            end

            set display_wt (string replace $HOME '~' $worktree)
            set display_slug $slug
            if test (string length $display_slug) -gt 44
                set display_slug (string sub -l 44 $display_slug)..
            end
            if test (string length $display_wt) -gt 43
                set display_wt ..(string sub -s (math (string length $display_wt) - 41) $display_wt)
            end

            printf "%-46s  %-9s  %-9s  %-45s  %s\n" \
                $display_slug $state_colored "host" $display_wt $updated_at
        end
    end

    if not $json_mode
        echo ""
        echo "Attach: byobu attach-session -t $CLXD_TMUX_SESSION"
        echo "Switch: Ctrl+a w"
    end
end

function _clxd_notify_daemon
    # Watch host status files; fire notify-send on transitions to waiting/idle
    if not command -q inotifywait; or not command -q notify-send
        return
    end
    mkdir -p $CLXD_STATUS_HOST_DIR
    inotifywait -m -r -e moved_to -q --format '%w%f' $CLXD_STATUS_HOST_DIR 2>/dev/null \
        | while read -l path
        if not string match -q '*/status.json' $path
            continue
        end
        set slug (string replace -r '^.*/([^/]+)/status\.json$' '$1' $path)
        set state (jq -r '.state // ""' $path 2>/dev/null)
        test -z "$state"; and continue
        set prev_file "$CLXD_STATUS_HOST_DIR/$slug/.prev_notify_state"
        set prev (cat $prev_file 2>/dev/null; or echo "")
        echo $state > $prev_file
        test "$state" = "$prev"; and continue
        if tmux list-windows -t $CLXD_TMUX_SESSION -F '#{window_active}#{window_name}' 2>/dev/null | grep -q "^1$slug\$"
            continue
        end
        switch $state
            case waiting
                set msg (jq -r '.message // ""' $path 2>/dev/null)
                notify-send -i dialog-question \
                    -h boolean:transient:true \
                    -h string:sound-name:message-new-instant \
                    "Claude waiting" "[$slug] $msg"
            case idle
                notify-send -i dialog-information \
                    -h boolean:transient:true \
                    -h string:sound-name:message-new-instant \
                    "Claude idle" "[$slug]"
        end
    end
end

function _clxd_dash
    # Title the tab/window this dashboard runs in
    _clxd_mux name_self dash

    if not command -q fzf
        echo "Note: install fzf for interactive mode (apt install fzf). Falling back to static display."
        while true
            clear
            _clxd_status --color
            sleep 2
        end
        return
    end

    set notify_pid ""
    if test "$CLXD_NOTIFY_SEND" = true; and command -q inotifywait; and command -q notify-send
        fish $_CLXD_BIN _notify-daemon &
        set notify_pid $last_pid
    end

    while true
        set port 16266

        # Background process: every 2s, GET current cursor position then POST reload+pos to
        # refresh the list without moving the selection. Uses fzf --listen HTTP API.
        fish -c "
            while sleep 2
                set resp (curl -s 'http://127.0.0.1:$port' 2>/dev/null)
                test -z \"\$resp\"; and continue
                set pos (printf '%s' \"\$resp\" | jq -r '.position // 0' 2>/dev/null; or echo 0)
                set pos1 (math \$pos + 1)
                curl -s -X POST 'http://127.0.0.1:$port' \
                    --data \"reload-sync($_CLXD_BIN _dash-ls)+pos(\$pos1)\" >/dev/null 2>&1
            end
        " &
        set bg_pid $last_pid

        # Field 1 (before tab) = slug; field 2+ = display. --with-nth 2 hides field 1.
        set selected ($_CLXD_BIN _dash-ls | fzf \
            --ansi \
            --listen $port \
            --delimiter "\t" \
            --with-nth 2 \
            --layout=reverse \
            --height 100% \
            --no-info \
            --header 'Enter=jump/relaunch' \
            --preview "$_CLXD_BIN _dash-preview {1}" \
            --preview-window 'down,30%,wrap')

        kill $bg_pid 2>/dev/null

        if test (count $selected) -eq 0
            break
        end

        set slug (echo $selected[1] | awk -F'\t' '{print $1}')
        if test -z "$slug"
            continue
        end

        if contains $slug (_clxd_mux list)
            # Live session: focus it
            _clxd_mux focus $slug
        else
            # No live session: (re)launch it, then focus
            if string match -q 'host-*' $slug
                set _status $CLXD_STATUS_HOST_DIR/$slug/status.json
                set _wt (jq -r '.worktree // ""' $_status 2>/dev/null; or true)
                if test -n "$_wt"
                    set _cmd "env CLXD_SLUG=$slug CLXD_WORKTREE=$_wt CLXD_STATUS_DIR=$CLXD_STATUS_HOST_DIR/$slug claude"
                    _clxd_mux open $slug $_cmd $_wt
                    _clxd_mux focus $slug
                end
            else
                set _name "clxd-$slug"
                set _wt (lxc config get $_name user.workspace.host-path 2>/dev/null)
                if test -n "$_wt"
                    set _cmd "lxc exec $_name --cwd $_wt -- su --pty agent -c 'claude'"
                    _clxd_mux open $slug $_cmd
                    _clxd_mux focus $slug
                end
            end
        end
        # Loop: relaunch picker so returning to dash window shows fresh list
    end

    if test -n "$notify_pid"
        kill $notify_pid 2>/dev/null
    end
end

function _clxd_dash_emit_sorted
    # Emits bucket rows sorted by timestamp (newest first).
    # Each element in $argv is "<iso-ts>\t<display-line>".
    if test (count $argv) -eq 0
        return
    end
    for r in (printf '%s\n' $argv | sort -r)
        string replace -r '^[^\t]*\t' '' $r
    end
end

function _clxd_dash_ls
    # One lxc call fetches name + config for all containers at once (avoids per-container API calls)
    set container_rows (lxc list --format json 2>/dev/null | jq -r '
        .[] | select(.name | startswith("clxd-"))
            | select(.config["user.workspace.slug"]) |
        [.name,
         .config["user.workspace.slug"],
         (.config["user.workspace.host-path"] // "")] | @tsv
    ' 2>/dev/null)

    # Live session slugs (from the active multiplexer) for dead-session detection
    set active_windows (_clxd_mux list)

    # Check if there are any host sessions
    set has_host (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null | head -1)

    if test -z "$container_rows" -a -z "$has_host"
        printf "\t(no sessions — run clxd launch in a worktree)\n"
        return
    end

    # Rows bucketed by state for sorted output: waiting > working > idle > other > dead
    set rows_waiting
    set rows_working
    set rows_idle
    set rows_other
    set rows_dead

    # Container rows (📦)
    for row in (string split \n $container_rows)
        test -z "$row"; and continue

        set name    (printf '%s' $row | cut -f1)
        set slug    (printf '%s' $row | cut -f2)
        set worktree (printf '%s' $row | cut -f3)

        set agent_state unknown
        set updated_at_raw 0
        set updated_at --

        set status_file $CLXD_STATUS_HOST_DIR/$name/status.json
        if test -f $status_file
            set agent_state (jq -r '.state // "unknown"' $status_file 2>/dev/null; or echo unknown)
            set updated_at_raw (jq -r '.updated_at // "0"' $status_file 2>/dev/null; or echo 0)
            set updated_at $updated_at_raw

            if test "$updated_at" != "0"
                set epoch_then (date -d $updated_at +%s 2>/dev/null; or echo 0)
                set epoch_now (date +%s)
                set diff (math $epoch_now - $epoch_then)
                if test $diff -lt 60
                    set updated_at "$diff""s"
                else if test $diff -lt 3600
                    set updated_at (math --scale=0 $diff / 60)"m"
                else
                    set updated_at (math --scale=0 $diff / 3600)"h"
                end
            else
                set updated_at --
            end
        end

        if not contains $slug $active_windows
            set agent_state dead
        end

        switch $agent_state
            case working;  set sc (printf "\e[36m%s\e[0m" $agent_state)
            case waiting;  set sc (printf "\e[33m%s\e[0m" $agent_state)
            case idle;     set sc (printf "\e[32m%s\e[0m" $agent_state)
            case dead;     set sc (printf "\e[31m%s\e[0m" $agent_state)
            case '*';      set sc (printf "\e[2m%s\e[0m"  $agent_state)
        end
        set pad (string repeat -n (math 9 - (string length $agent_state)) " ")
        set display_wt (string replace $HOME '~' $worktree)
        if test (string length $display_wt) -gt 55
            set _bn (string split '/' $display_wt)[-1]
            set _pl (math 53 - (string length $_bn))
            if test $_pl -ge 3
                set display_wt (string sub -l $_pl $display_wt)…/$_bn
            else
                set display_wt ..(string sub -s (math (string length $display_wt) - 52) $display_wt)
            end
        end
        # Prefix with raw timestamp for within-bucket sort (stripped before output)
        set line (printf "%s\t%s\t📦 %-57s  %s%s  %s" $updated_at_raw $slug $display_wt $sc $pad $updated_at)
        switch $agent_state
            case waiting;  set -a rows_waiting $line
            case working;  set -a rows_working $line
            case idle;     set -a rows_idle    $line
            case dead;     set -a rows_dead    $line
            case '*';      set -a rows_other   $line
        end
    end

    # Host session rows (🏠)
    for dir in (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null)
        set slug (basename $dir)
        set worktree ""
        set agent_state unknown
        set updated_at_raw 0
        set updated_at --

        set status_file $dir/status.json
        if test -f $status_file
            set worktree (jq -r '.worktree // ""' $status_file 2>/dev/null; or true)
            set agent_state (jq -r '.state // "unknown"' $status_file 2>/dev/null; or echo unknown)
            set updated_at_raw (jq -r '.updated_at // "0"' $status_file 2>/dev/null; or echo 0)
            set updated_at $updated_at_raw

            if test "$updated_at" != "0"
                set epoch_then (date -d $updated_at +%s 2>/dev/null; or echo 0)
                set epoch_now (date +%s)
                set diff (math $epoch_now - $epoch_then)
                if test $diff -lt 60
                    set updated_at "$diff""s"
                else if test $diff -lt 3600
                    set updated_at (math --scale=0 $diff / 60)"m"
                else
                    set updated_at (math --scale=0 $diff / 3600)"h"
                end
            else
                set updated_at --
            end
        end

        if not contains $slug $active_windows
            set agent_state dead
        end

        switch $agent_state
            case working;  set sc (printf "\e[36m%s\e[0m" $agent_state)
            case waiting;  set sc (printf "\e[33m%s\e[0m" $agent_state)
            case idle;     set sc (printf "\e[32m%s\e[0m" $agent_state)
            case dead;     set sc (printf "\e[31m%s\e[0m" $agent_state)
            case '*';      set sc (printf "\e[2m%s\e[0m"  $agent_state)
        end
        set pad (string repeat -n (math 9 - (string length $agent_state)) " ")
        set display_wt (string replace $HOME '~' $worktree)
        if test (string length $display_wt) -gt 55
            set _bn (string split '/' $display_wt)[-1]
            set _pl (math 53 - (string length $_bn))
            if test $_pl -ge 3
                set display_wt (string sub -l $_pl $display_wt)…/$_bn
            else
                set display_wt ..(string sub -s (math (string length $display_wt) - 52) $display_wt)
            end
        end
        set line (printf "%s\t%s\t🏠 %-57s  %s%s  %s" $updated_at_raw $slug $display_wt $sc $pad $updated_at)
        switch $agent_state
            case waiting;  set -a rows_waiting $line
            case working;  set -a rows_working $line
            case idle;     set -a rows_idle    $line
            case dead;     set -a rows_dead    $line
            case '*';      set -a rows_other   $line
        end
    end

    # Emit in priority order: waiting → working → idle → other → dead
    # Within each bucket, newest first (timestamp prefix stripped by helper)
    _clxd_dash_emit_sorted $rows_waiting
    _clxd_dash_emit_sorted $rows_working
    _clxd_dash_emit_sorted $rows_idle
    _clxd_dash_emit_sorted $rows_other
    _clxd_dash_emit_sorted $rows_dead
end

function _clxd_dash_preview
    set slug $argv[1]
    if test -z "$slug"
        echo "No session selected."
        return
    end

    # Placeholder row from empty list: skip quietly
    if string match -q '' $slug; or string match -q '(*' $slug
        return
    end

    set is_host (string match -q 'host-*' $slug; and echo true; or echo false)

    if $is_host
        set name $slug
        set worktree (jq -r '.worktree // ""' $CLXD_STATUS_HOST_DIR/$name/status.json 2>/dev/null; or true)
        set container_state "host"
    else
        set name "clxd-$slug"
        set worktree (lxc config get $name user.workspace.host-path 2>/dev/null)
        set container_state (lxc info $name 2>/dev/null | awk '/^Status:/ {print tolower($2)}')
    end

    set agent_state unknown
    set updated_at --
    set message ""

    set status_file $CLXD_STATUS_HOST_DIR/$name/status.json
    if test -f $status_file
        set agent_state (jq -r '.state // "unknown"' $status_file 2>/dev/null; or echo unknown)
        set updated_at (jq -r '.updated_at // "--"' $status_file 2>/dev/null; or echo --)
        set message (jq -r '.message // ""' $status_file 2>/dev/null; or true)
    end

    # Convert updated_at to relative time
    set updated_rel $updated_at
    if test "$updated_at" != "--"
        set epoch_then (date -d $updated_at +%s 2>/dev/null; or echo 0)
        set epoch_now (date +%s)
        set diff (math $epoch_now - $epoch_then)
        if test $diff -lt 60
            set updated_rel "$diff""s ago"
        else if test $diff -lt 3600
            set updated_rel (math --scale=0 $diff / 60)"m ago"
        else
            set updated_rel (math --scale=0 $diff / 3600)"h ago"
        end
    end

    if $is_host
        printf "Session:    %s (host)\n" $name
    else
        printf "Container:  %s\n" $name
    end
    printf "Worktree:   %s\n" $worktree
    printf "State:      %s / %s\n" $container_state $agent_state
    if test -n "$message"
        printf "Activity:   %s\n" $message
    end
    printf "Updated:    %s\n" $updated_rel

    set events_file $CLXD_STATUS_HOST_DIR/$name/events.jsonl
    if test -f $events_file
        set recent (tail -5 $events_file 2>/dev/null)
        if test -n "$recent"
            echo ""
            echo "Recent events:"
            for line in $recent
                set ts (echo $line | jq -r '.ts // ""' 2>/dev/null)
                set st (echo $line | jq -r '.state // ""' 2>/dev/null)
                set msg (echo $line | jq -r '.message // ""' 2>/dev/null)
                printf "  %-22s  %-8s  %s\n" $ts $st $msg
            end
        end
    end
end

function _clxd_attach
    set target ""
    if test (count $argv) -gt 0
        set target $argv[1]
    end

    # No target (use $PWD) or a path target: resolve worktree → prefer live session
    set resolve_path ""
    if test -z "$target"
        set resolve_path $PWD
    else if test -d $target
        set resolve_path $target
    end

    if test -n "$resolve_path"
        if _clxd_worktree_info $resolve_path 2>/dev/null
            set container_slug (string replace 'clxd-' '' (_clxd_slug $_wt_path))
            set host_slug (_clxd_host_slug $_wt_path)
            set live (_clxd_mux list)
            if contains $container_slug $live
                _clxd_mux attach $container_slug
            else if contains $host_slug $live
                _clxd_mux attach $host_slug
            else
                _clxd_mux attach $container_slug
            end
            return
        end
        if test -z "$target"
            # Not in a worktree — just attach to the multiplexer
            _clxd_mux attach
            return
        end
    end

    # Otherwise treat as slug directly
    _clxd_mux attach $target
end

function _clxd_ls
    set containers (lxc list --format csv -c n 2>/dev/null | grep '^clxd-'; or true)
    for name in (string split \n $containers)
        test -z "$name"; and continue
        set worktree (lxc config get $name user.workspace.host-path 2>/dev/null)
        set slug (lxc config get $name user.workspace.slug 2>/dev/null)
        set state (lxc info $name 2>/dev/null | awk '/^Status:/ {print tolower($2)}')
        set agent_state (jq -r '.state // "unknown"' $CLXD_STATUS_HOST_DIR/$name/status.json 2>/dev/null; or echo unknown)
        echo "$name\t$slug\t$state\t$agent_state\t$worktree"
    end
    for dir in (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null)
        set slug (basename $dir)
        set worktree (jq -r '.worktree // ""' $dir/status.json 2>/dev/null; or true)
        set agent_state (jq -r '.state // "unknown"' $dir/status.json 2>/dev/null; or echo unknown)
        echo "$slug\t$slug\thost\t$agent_state\t$worktree"
    end
end

function _clxd_stop
    set path $PWD
    if test (count $argv) -gt 0
        set path $argv[1]
    end

    if not _clxd_worktree_info $path
        exit 1
    end

    set name (_clxd_slug $_wt_path)

    if not lxc info $name > /dev/null 2>&1
        echo "No container found for $path" >&2
        exit 1
    end

    echo "Stopping $name..."
    if not lxc stop $name
        echo "Error: failed to stop $name" >&2
        exit 1
    end
    echo "Stopped."
end

function _clxd_destroy
    set path $PWD
    if test (count $argv) -gt 0
        set path $argv[1]
    end

    if not _clxd_worktree_info $path 2>/dev/null
        # Path may no longer be a git repo (worktree already removed)
        # Derive name from the path directly
        set name (_clxd_slug (realpath $path 2>/dev/null; or echo $path))
    else
        set name (_clxd_slug $_wt_path)
    end

    if not lxc info $name > /dev/null 2>&1
        echo "No container found: $name" >&2
        exit 1
    end

    echo "Destroying $name..."
    lxc stop --force $name 2>/dev/null; or true
    if not lxc delete $name
        echo "Error: failed to delete $name" >&2
        exit 1
    end
    rm -rf $CLXD_STATUS_HOST_DIR/$name
    echo "Destroyed."
end

function _clxd_gc
    set dry_run false
    for arg in $argv
        if test "$arg" = --dry-run
            set dry_run true
        end
    end

    set containers (lxc list --format csv -c n 2>/dev/null | grep '^clxd-'; or true)
    set removed 0

    for name in (string split \n $containers)
        test -z "$name"; and continue

        set worktree (lxc config get $name user.workspace.host-path 2>/dev/null)

        if test -n "$worktree" -a ! -d "$worktree"
            if $dry_run
                echo "[dry-run] Would remove: $name"
                echo "          worktree gone: $worktree"
            else
                echo "Removing orphan: $name (worktree: $worktree)"
                lxc stop --force $name 2>/dev/null; or true
                if not lxc delete $name
                    echo "Error: failed to delete $name — skipping" >&2
                    continue
                end
                rm -rf $CLXD_STATUS_HOST_DIR/$name
                set removed (math $removed + 1)
            end
        end
    end

    # Host sessions: remove status dirs for gone worktrees
    for dir in (find $CLXD_STATUS_HOST_DIR -maxdepth 1 -type d -name 'host-*' 2>/dev/null)
        set slug (basename $dir)
        set worktree (jq -r '.worktree // ""' $dir/status.json 2>/dev/null; or true)

        if test -n "$worktree" -a ! -d "$worktree"
            if $dry_run
                echo "[dry-run] Would remove host session: $slug"
                echo "          worktree gone: $worktree"
            else
                echo "Removing orphan host session: $slug (worktree: $worktree)"
                rm -rf $dir
                set removed (math $removed + 1)
            end
        end
    end

    if test $removed -gt 0
        echo "$removed session(s) removed."
    else if not $dry_run
        echo "No orphan sessions found."
    end
end

function _clxd_build_image
    # Delegate to image/build.fish
    set build_script $_CLXD_ROOT/image/build.fish
    if not test -f $build_script
        echo "Error: build script not found: $build_script" >&2
        exit 1
    end
    fish $build_script $argv; or exit 1
end

function _clxd_list_images
    echo "Local claude-in-lxd images:"
    lxc image list --format table local: | grep claude-in-lxd
end

function _clxd_profile_yaml_hash
    sha256sum $_CLXD_ROOT/profile.yaml | cut -d' ' -f1
end

function _clxd_check_profile_freshness
    set live (lxc profile get claude-in-lxd user.clxd.source-hash 2>/dev/null | string trim)
    set current (_clxd_profile_yaml_hash)
    if test -z "$live"
        echo "warning: live LXD profile 'claude-in-lxd' has no source-hash stamp." >&2
        echo "         Run 'clxd update-profile' to apply the current profile.yaml." >&2
    else if test "$live" != "$current"
        echo "warning: profile.yaml has changed since the live profile was last applied." >&2
        echo "         Run 'clxd update-profile' to apply, then restart containers to pick it up." >&2
    end
end

function _clxd_update_profile
    if not lxc profile list | grep -q "^| claude-in-lxd "
        echo "Profile 'claude-in-lxd' does not exist yet. Run 'clxd build-image' to create it." >&2
        return 1
    end

    echo "Applying $_CLXD_ROOT/profile.yaml to LXD profile 'claude-in-lxd'..."
    lxc profile edit claude-in-lxd < $_CLXD_ROOT/profile.yaml; or return 1
    lxc profile set claude-in-lxd user.clxd.source-hash (_clxd_profile_yaml_hash); or return 1
    echo "Profile updated."

    set users (lxc list -c name,profiles -f csv 2>/dev/null \
        | string match -r '^[^,]+,.*claude-in-lxd' \
        | string replace -r ',.*' '')
    if test (count $users) -gt 0
        echo ""
        echo "Containers using this profile:"
        for c in $users
            echo "  - $c"
        end
        echo ""
        echo "Most limits.* keys hot-apply, but a restart guarantees the full profile takes effect:"
        echo "  for c in $users; lxc restart \$c; end"
    end
end

function _clxd_setup_network
    set domains
    if command -q resolvectl
        for line in (resolvectl domain 2>/dev/null)
            for tok in (string split ' ' (string replace -r '^[^:]+:' '' $line))
                test -n "$tok"; and test "$tok" != '~.'; and set -a domains $tok
            end
        end
    end
    if test (count $domains) -eq 0
        for line in (grep '^search ' /etc/resolv.conf 2>/dev/null)
            for tok in (string split ' ' (string replace -r '^search +' '' $line))
                test -n "$tok"; and set -a domains $tok
            end
        end
    end

    if test (count $domains) -eq 0
        echo "No host search domain detected — nothing to configure."
        return 0
    end

    set uniq
    for d in $domains
        contains $d $uniq; or set -a uniq $d
    end
    set list (string join , $uniq)

    set current (lxc network get lxdbr0 dns.search 2>/dev/null)
    if test "$current" = "$list"
        echo "lxdbr0 dns.search already set to '$list' — nothing to do."
        return 0
    end

    echo "Setting lxdbr0 dns.search=$list"
    lxc network set lxdbr0 dns.search $list; or return 1

    echo ""
    echo "Done. Running containers will not pick up the new search domain until"
    echo "their next DHCP renewal. To force it: clxd stop <path> && clxd launch <path>"
end

function _clxd_help
    echo "Usage: clxd [<subcommand>] [options]"
    echo ""
    echo "  clxd [launch] [--image <alias>] [path]"
    echo "    Launch Claude agent in an LXD container for the given worktree."
    echo "    Defaults to \$PWD. Creates the container if needed."
    echo ""
    echo "  clxd launch --host [path]"
    echo "    Launch Claude agent directly on the host (no container)."
    echo "    Uses default permission mode — Claude prompts for each tool approval."
    echo "    Appears on the dashboard and produces the same notifications."
    echo "    Note: parallel host sessions share ~/.claude state."
    echo ""
    echo "  clxd setup-host               Register hooks in ~/.claude/settings.json"
    echo "    (run automatically by 'launch --host'; re-run to refresh after upgrade)"
    echo ""
    echo "  clxd shell   [path]            Open a bash shell in the container"
    echo "  clxd exec    [path] -- cmd...  Run a command inside the container"
    echo "  clxd attach  [path|slug]       Attach to a session's byobu window"
    echo "  clxd stop    [path]            Stop the container (keep data)"
    echo "  clxd destroy [path]            Stop + delete the container"
    echo ""
    echo "  clxd status  [--json]          One-shot status table (containers + host)"
    echo "  clxd dash                      Live-updating status dashboard"
    echo "  clxd ls                        Machine-readable session list"
    echo ""
    echo "  clxd gc      [--dry-run]       Remove orphan containers/host sessions"
    echo ""
    echo "  clxd build-image [profile] [--from dir]"
    echo "    Build the base image (or a profile layer on top of it)."
    echo "    Example: clxd build-image zivid --from ~/.config/clxd/profiles/zivid"
    echo ""
    echo "  clxd list-images               List local claude-in-lxd* images
  clxd setup-network             Propagate host DNS search domain to lxdbr0
  clxd update-profile            Re-apply profile.yaml to the live LXD profile"
    echo ""
    echo "Image selection (in order of precedence):"
    echo "  1. --image <alias>"
    echo "  2. .clxd-image file in worktree root"
    echo "  3. .clxd-image file in main worktree root (inherited by gwt)"
    echo "  4. Default: claude-in-lxd"
    echo ""
end

# ── Entry point ───────────────────────────────────────────────────────────────

main $argv
